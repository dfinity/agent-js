{
  "name": "@dfinity/internal",
  "version": "0.0.1",
  "private": true,
  "exports": {
    "./bytes": {
      "types": {
        "import": "./lib/esm/bytes/index.d.ts",
        "require": "./lib/cjs/bytes/index.d.ts"
      },
      "import": "./lib/esm/bytes/index.js",
      "require": "./lib/cjs/bytes/index.js"
    },
    "./signatures": {
      "types": {
        "import": "./lib/esm/signatures/index.d.ts",
        "require": "./lib/cjs/signatures/index.d.ts"
      },
      "import": "./lib/esm/signatures/index.js",
      "require": "./lib/cjs/signatures/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b && tsc -p tsconfig.cjs.json",
    "lint": "eslint 'src' --ext '.js,.jsx,.ts,.tsx'",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:coverage": "jest --collectCoverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "esbuild": "^0.25.1",
    "eslint": "^8.19.0",
    "jest": "^29.7.0",
    "typescript": "5.8.3"
  }
}
