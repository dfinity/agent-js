{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "lib/esm",
    "tsBuildInfoFile": "./build_info.json",

    "paths": {
      "@dfinity/internal/*": ["../internal/src/*"]
    }
  },
  "include": ["types/*", "src/**/*.ts"],
  "exclude": [
    "**/src/**/__certificates__/**",
    "**/src/**/*.test.ts",
    "**/src/**/*.spec.ts",
    "**/src/**/*.snap",
    "test-setup.ts",
    "node_modules",
    "dist",
    "lib"
  ]
}
